<?xml version="1.0" encoding="utf-8"?>
<!--
  Chỉ áp dụng cho build DEBUG (nằm ở src/debug, không phải src/main), cho
  phép gọi HTTP thường (không TLS) tới backend PayOS chạy local khi dev:
  - 10.0.2.2 : địa chỉ loopback của máy host khi chạy trên Android Emulator
  - localhost/127.0.0.1: khi chạy trên thiết bị thật qua adb reverse
  Bản release KHÔNG có file này nên vẫn bị chặn cleartext như mặc định
  Android yêu cầu - an toàn cho production.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
